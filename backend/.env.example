# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/findyourteacher?sslmode=require"

# JWT
JWT_ACCESS_SECRET="change-me-min-32-chars-long-secret-here"
JWT_REFRESH_SECRET="change-me-different-min-32-chars-secret"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# App
PORT=3001
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"
