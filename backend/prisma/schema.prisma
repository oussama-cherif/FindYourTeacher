generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum OnboardingCallStatus {
  PENDING
  CONFIRMED
  DONE
  CANCELLED
}

enum GroupMembershipStatus {
  PENDING
  ACTIVE
  LEFT
  REMOVED
}

enum SessionStatus {
  SCHEDULED
  LIVE
  DONE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── Users ──────────────────────────────────────────────────────

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          UserRole @default(STUDENT)
  fullName      String   @map("full_name")
  avatarUrl     String?  @map("avatar_url")
  phone         String?
  locale        String   @default("fr")
  isVerified    Boolean  @default(false) @map("is_verified")
  isActive      Boolean  @default(true) @map("is_active")
  refreshToken  String?  @map("refresh_token")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  teacherProfile    TeacherProfile?
  onboardingCalls   OnboardingCall[]   @relation("StudentCalls")
  teacherCalls      OnboardingCall[]   @relation("TeacherCalls")
  groupMemberships  GroupMembership[]
  sessionPayments   SessionPayment[]
  uploadedFiles     File[]
  recommendations   Recommendation[]   @relation("StudentRecommendations")
  receivedRecs      Recommendation[]   @relation("TeacherRecommendations")
  availabilitySlots AvailabilitySlot[]

  @@map("users")
}

// ─── Teacher Profiles ───────────────────────────────────────────

model TeacherProfile {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String             @unique @map("user_id") @db.Uuid
  bio                   String?
  languages             String[]
  audienceTypes         String[]           @map("audience_types")
  diplomaUrl            String?            @map("diploma_url")
  idDocUrl              String?            @map("id_doc_url")
  recommendationCount   Int                @default(0) @map("recommendation_count")
  hasStarBadge          Boolean            @default(false) @map("has_star_badge")
  subscriptionStatus    SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups Group[]

  @@map("teacher_profiles")
}

// ─── Availability Slots ─────────────────────────────────────────

model AvailabilitySlot {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId String  @map("teacher_id") @db.Uuid
  dayOfWeek Int     @map("day_of_week") // 0=Monday .. 6=Sunday
  startTime String  @map("start_time") // "14:00"
  endTime   String  @map("end_time") // "15:00"
  isBooked  Boolean @default(false) @map("is_booked")

  teacher         User             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  onboardingCalls OnboardingCall[]

  @@map("availability_slots")
}

// ─── Onboarding Calls ───────────────────────────────────────────

model OnboardingCall {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId          String               @map("student_id") @db.Uuid
  teacherId          String               @map("teacher_id") @db.Uuid
  slotId             String               @map("slot_id") @db.Uuid
  scheduledAt        DateTime             @map("scheduled_at") @db.Timestamptz
  status             OnboardingCallStatus @default(PENDING)
  studentNotes       String?              @map("student_notes")
  dismissedByTeacher Boolean              @default(false) @map("dismissed_by_teacher")

  student User             @relation("StudentCalls", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User             @relation("TeacherCalls", fields: [teacherId], references: [id], onDelete: Cascade)
  slot    AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@map("onboarding_calls")
}

// ─── Groups ─────────────────────────────────────────────────────

model Group {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId       String  @map("teacher_id") @db.Uuid
  name            String
  language        String
  level           String // A1 | A2 | B1 | B2 | C1 | C2
  audienceType    String  @map("audience_type") // kids | adults | workers | elderly
  maxStudents     Int     @map("max_students")
  pricePerSession Decimal @map("price_per_session") @db.Decimal(10, 3)
  platformFee     Decimal @default(10.000) @map("platform_fee") @db.Decimal(10, 3)
  isActive        Boolean @default(true) @map("is_active")

  teacher     TeacherProfile    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  memberships GroupMembership[]
  sessions    Session[]
  files       File[]

  @@map("groups")
}

// ─── Group Memberships ──────────────────────────────────────────

model GroupMembership {
  id        String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId   String                @map("group_id") @db.Uuid
  studentId String                @map("student_id") @db.Uuid
  status    GroupMembershipStatus @default(PENDING)
  joinedAt  DateTime              @default(now()) @map("joined_at") @db.Timestamptz

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@map("group_memberships")
}

// ─── Sessions ───────────────────────────────────────────────────

model Session {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId         String        @map("group_id") @db.Uuid
  scheduledAt     DateTime      @map("scheduled_at") @db.Timestamptz
  durationMinutes Int           @default(60) @map("duration_minutes")
  jitsiRoomId     String        @unique @map("jitsi_room_id")
  status          SessionStatus @default(SCHEDULED)
  recordingUrl    String?       @map("recording_url")

  group    Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payments SessionPayment[]

  @@map("sessions")
}

// ─── Session Payments ───────────────────────────────────────────

model SessionPayment {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String        @map("session_id") @db.Uuid
  studentId    String        @map("student_id") @db.Uuid
  amountPaid   Decimal       @map("amount_paid") @db.Decimal(10, 3)
  platformFee  Decimal       @map("platform_fee") @db.Decimal(10, 3)
  teacherNet   Decimal       @map("teacher_net") @db.Decimal(10, 3)
  gatewayTxId  String?       @map("gateway_tx_id")
  status       PaymentStatus @default(PENDING)
  paidAt       DateTime?     @map("paid_at") @db.Timestamptz

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("session_payments")
}

// ─── Files ──────────────────────────────────────────────────────

model File {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId       String   @map("group_id") @db.Uuid
  uploadedBy    String   @map("uploaded_by") @db.Uuid
  fileName      String   @map("file_name")
  fileUrl       String   @map("file_url")
  fileSizeBytes Int      @map("file_size_bytes")
  uploadedAt    DateTime @default(now()) @map("uploaded_at") @db.Timestamptz

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  uploader User  @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@map("files")
}

// ─── Recommendations ────────────────────────────────────────────

model Recommendation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  comment   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  teacher User @relation("TeacherRecommendations", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentRecommendations", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId])
  @@map("recommendations")
}
